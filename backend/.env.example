# Core LLM scanner configuration
LLM_MODEL_ID=mlx-community/Meta-Llama-3-8B-Instruct-4bit
LLM_ADAPTER_PATH=./adapters
LLM_MAX_TOKENS=200

# Set true for dry-run mode (skips model loading/inference for quick smoke checks)
LLM_DRY_RUN=false

# Ollama verifier configuration for src/llm_engine.py
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=15
